# Slack Bot Token (required)
# Get from: https://api.slack.com/apps → Your App → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-token-here
# Slack Channels (required)
# Comma-separated list of channel IDs to monitor
# Find channel IDs: Right-click channel → View channel details → Copy ID
SLACK_CHANNELS=C0ABJTT6LLC,C1234567890